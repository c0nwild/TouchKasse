create table tr_list (
tr_id integer primary key autoincrement,
DATE txt not null,
BILL float not null,
CASH float not null,
KK integer not null,
LK integer not null,
LKW integer not null,
LSB integer not null,
GB integer not null,
MB integer not null,
B integer not null,
SB integer not null,
LS integer not null,
POTTK integer not null,
